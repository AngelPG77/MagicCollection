<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Google Fonts cert array. Required by androidx.compose.ui.text.googlefonts.GoogleFont.Provider
      so Compose can verify the signing certificate of the com.google.android.gms.fonts provider
      package before fetching font files.

      Source: https://developer.android.com/develop/ui/views/text-and-emoji/downloadable-fonts#programmatic
    -->
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>

        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>

        </item>
    </string-array>
</resources>
